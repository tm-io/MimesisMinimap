<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>c0bbb902-2061-468d-994d-747820fad136</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>MimesisMinimap</RootNamespace>
    <AssemblyName>MimesisMinimap</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- ゲームのManagedフォルダ（要変更可） -->
    <MIMESIS_MANAGED Condition="'$(MIMESIS_MANAGED)' == ''">D:\Steam\steamapps\common\MIMESIS\MIMESIS_Data\Managed</MIMESIS_MANAGED>
    <MIMESIS_ROOT Condition="'$(MIMESIS_ROOT)' == ''">D:\Steam\steamapps\common\MIMESIS</MIMESIS_ROOT>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Xml" />
    <!-- Unity (ゲームのManagedから) -->
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.IMGUIModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.InputLegacyModule.dll</HintPath>
    </Reference>
    <Reference Include="Unity.InputSystem">
      <HintPath>$(MIMESIS_MANAGED)\Unity.InputSystem.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.PhysicsModule">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.PhysicsModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.UIModule">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.UIModule.dll</HintPath>
    </Reference>
    <!-- 旧 Unity では UI が UnityEngine.UI.dll の場合あり -->
    <Reference Include="UnityEngine.UI">
      <HintPath>$(MIMESIS_MANAGED)\UnityEngine.UI.dll</HintPath>
    </Reference>
    <!-- ゲーム本体 -->
    <Reference Include="Assembly-CSharp">
      <HintPath>$(MIMESIS_MANAGED)\Assembly-CSharp.dll</HintPath>
    </Reference>
    <!-- MelonLoader: Lib\MelonLoader.dll を配置するか、ゲーム側の MelonLoader フォルダを指定 -->
    <Reference Include="MelonLoader">
      <HintPath>$(ProjectDir)Lib\MelonLoader.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="MimesisMinimapMod.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
